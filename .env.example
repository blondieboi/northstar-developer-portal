PORT=4000
# Canonical Git-backed configuration location.
PERONGEN_CONFIG_REPOSITORY=your-org/portal-config
PERONGEN_CONFIG_BRANCH=main
PERONGEN_CONFIG_DIRECTORY=perongen
PERONGEN_CONFIG_INSTALLATION_ID=
PERONGEN_CONFIG_POLL_INTERVAL_SECONDS=60
# Legacy input used only by `npm run config:export`.
PERONGEN_CONFIG_PATH=./perongen.yaml
DATABASE_URL=postgres://perongen:perongen@localhost:5440/perongen
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Alternatively mount the key and use an absolute path:
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
PUBLIC_URL=http://localhost:4000
# The browser UI origin. Keep this at Vite's dev-server URL when running `npm run dev`.
APP_URL=http://localhost:5173
# Number of reverse-proxy hops to trust for client IPs. Production defaults to one; use 0 only without a proxy.
TRUST_PROXY_HOPS=0
# Comma-separated GitHub organization slugs. Active membership in any listed organization grants access.
GITHUB_ALLOWED_ORGANIZATIONS=your-org
# Comma-separated immutable GitHub user IDs for deployment break-glass administrators.
GITHUB_ADMIN_IDS=
GITHUB_INSTALLATION_ID=
ACTION_REPOSITORY=your-org/platform-automation
ACTION_WORKFLOW=bogus-provision.yml
