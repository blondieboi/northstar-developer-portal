PORT=4000
# Canonical Git-backed configuration location.
NORTHSTAR_CONFIG_REPOSITORY=your-org/portal-config
NORTHSTAR_CONFIG_BRANCH=main
NORTHSTAR_CONFIG_DIRECTORY=perongen
NORTHSTAR_CONFIG_INSTALLATION_ID=
NORTHSTAR_CONFIG_POLL_INTERVAL_SECONDS=60
# Legacy input used only by `npm run config:export`.
NORTHSTAR_CONFIG_PATH=./northstar.yaml
DATABASE_URL=postgres://northstar:northstar@localhost:5440/northstar
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Alternatively mount the key and use an absolute path:
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
SESSION_SECRET=replace-with-a-long-random-value
PUBLIC_URL=http://localhost:4000
# The browser UI origin. Keep this at Vite's dev-server URL when running `npm run dev`.
APP_URL=http://localhost:5173
# Comma-separated deployment break-glass administrators. These users cannot be demoted in the UI.
GITHUB_ADMIN_LOGINS=
GITHUB_INSTALLATION_ID=
ACTION_REPOSITORY=your-org/platform-automation
ACTION_WORKFLOW=bogus-provision.yml
