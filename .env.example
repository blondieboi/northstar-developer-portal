PORT=4000
DATABASE_URL=postgres://northstar:northstar@localhost:5440/northstar
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Alternatively mount the key and use an absolute path:
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
SESSION_SECRET=replace-with-a-long-random-value
PUBLIC_URL=http://localhost:4000
# Comma-separated GitHub usernames. If empty, any authenticated user is an admin.
GITHUB_ADMIN_LOGINS=
GITHUB_INSTALLATION_ID=
ACTION_REPOSITORY=your-org/platform-automation
ACTION_WORKFLOW=create-service.yaml
