{
  "name": "perongen-developer-portal",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:api": "node --env-file-if-exists=.env --import tsx --watch server/index.ts",
    "build": "tsc -b && vite build && npm run build:server",
    "build:server": "tsc -p server/tsconfig.build.json && node scripts/copy-server-assets.mjs",
    "start": "node --env-file-if-exists=.env build/server/index.js",
    "config:export": "node --env-file-if-exists=.env --import tsx server/config-export.ts",
    "admins:migrate": "node --env-file-if-exists=.env --import tsx server/migrate-admin-ids.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:tour": "swift scripts/render-launch-tour.swift",
    "preview": "vite preview --host 0.0.0.0",
    "check": "tsc -b && tsc -p server/tsconfig.json --noEmit",
    "test": "vitest run",
    "audit:production": "npm audit --omit=dev --audit-level=moderate"
  },
  "dependencies": {
    "@fastify/cors": "11.3.0",
    "@fastify/static": "9.3.0",
    "@octokit/app": "16.1.2",
    "@octokit/rest": "22.0.1",
    "fastify": "5.10.0",
    "lucide-react": "1.24.0",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "pg-mem": "3.0.14",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitepress": "1.6.4",
    "vitest": "4.1.10"
  }
}
